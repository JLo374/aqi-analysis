"""
AQI 監測站資料擷取與視覺化腳本
使用 MOENV API 獲取即時 AQI 資料並使用 Folium 繪製地圖
"""

import os
import sys
import subprocess
import json
from datetime import datetime
from pathlib import Path

def install_requirements():
    """自動安裝所需套件"""
    requirements_file = Path(__file__).parent.parent / 'requirements.txt'
    
    if requirements_file.exists():
        print("正在檢查並安裝所需套件...")
        try:
            subprocess.check_call([
                sys.executable, '-m', 'pip', 'install', '-r', str(requirements_file), '--quiet'
            ])
            print("✓ 套件安裝完成\n")
        except subprocess.CalledProcessError as e:
            print(f"⚠ 套件安裝時發生錯誤: {e}")
            sys.exit(1)
    else:
        print("找不到 requirements.txt 檔案")
        sys.exit(1)

# 自動安裝套件
install_requirements()

# 導入所需模組
import requests
from dotenv import load_dotenv
import folium
import pandas as pd

# 載入環境變數
env_path = Path(__file__).parent.parent / '.env'
load_dotenv(env_path)

# API 設定
MOENV_API_KEY = os.getenv('MOENV_API_KEY')
API_BASE_URL = 'https://data.moenv.gov.tw/api/v2'
DATASET_ID = 'aqx_p_432'  # AQI 資料集

def fetch_aqi_data(limit=1000, offset=0):
    """
    從 MOENV API 獲取 AQI 資料
    
    Parameters:
        limit (int): 每次請求的資料筆數上限
        offset (int): 資料偏移量
        
    Returns:
        dict: API 回應的 JSON 資料
    """
    if not MOENV_API_KEY:
        raise ValueError("❌ 找不到 MOENV_API_KEY，請確認 .env 檔案中已設定 API Key")
    
    url = f"{API_BASE_URL}/{DATASET_ID}"
    
    params = {
        'api_key': MOENV_API_KEY,
        'limit': limit,
        'offset': offset,
        'format': 'json'
    }
    
    print(f"正在從 MOENV API 獲取 AQI 資料...")
    print(f"API 端點: {url}")
    
    try:
        response = requests.get(url, params=params, timeout=30)
        response.raise_for_status()

        data = response.json()
        print(f"✓ 成功獲取資料")

        # 輸出 API 回應的結構以便除錯
        print(f"API 回應的頂層鍵值: {list(data.keys()) if isinstance(data, dict) else 'not a dict'}")

        return data

    except requests.exceptions.RequestException as e:
        print(f"❌ API 請求失敗: {e}")
        sys.exit(1)

def process_aqi_data(data):
    """
    處理 AQI 資料並轉換為 DataFrame

    Parameters:
        data (dict): API 回應的 JSON 資料

    Returns:
        pd.DataFrame: 處理後的資料
    """
    # 檢查不同可能的資料結構
    records = None

    if isinstance(data, list):
        # 如果 API 直接回傳陣列
        records = data
        print(f"✓ API 回傳陣列格式")
    elif isinstance(data, dict):
        # 嘗試不同的可能鍵值
        if 'records' in data:
            records = data['records']
        elif 'data' in data:
            records = data['data']
        elif 'result' in data:
            records = data['result']
        else:
            print(f"❌ API 回應格式不正確。可用的鍵值: {list(data.keys())}")
            return pd.DataFrame()
    else:
        print(f"❌ API 回應格式不正確（非陣列也非物件）")
        return pd.DataFrame()

    if not records:
        print("❌ 沒有找到資料記錄")
        return pd.DataFrame()

    df = pd.DataFrame(records)
    
    print(f"✓ 共獲取 {len(df)} 筆監測站資料")
    
    # 轉換數值型欄位
    numeric_columns = ['latitude', 'longitude', 'aqi']
    for col in numeric_columns:
        if col in df.columns:
            df[col] = pd.to_numeric(df[col], errors='coerce')
    
    # 移除無效的經緯度資料
    df = df.dropna(subset=['latitude', 'longitude'])
    df = df[(df['latitude'] != 0) & (df['longitude'] != 0)]
    
    print(f"✓ 處理後有效資料: {len(df)} 筆\n")
    
    return df

def get_aqi_color(aqi):
    """根據 AQI 值返回對應的顏色"""
    try:
        aqi_value = float(aqi) if pd.notna(aqi) else 0
    except (ValueError, TypeError):
        return 'gray'
    
    if aqi_value <= 50:
        return 'green'      # 良好
    elif aqi_value <= 100:
        return 'lightgreen' # 普通
    elif aqi_value <= 150:
        return 'orange'     # 對敏感族群不健康
    elif aqi_value <= 200:
        return 'red'        # 對所有族群不健康
    elif aqi_value <= 300:
        return 'purple'     # 非常不健康
    else:
        return 'darkred'    # 危害

def get_aqi_status(aqi):
    """根據 AQI 值返回狀態文字"""
    try:
        aqi_value = float(aqi) if pd.notna(aqi) else 0
    except (ValueError, TypeError):
        return '無資料'
    
    if aqi_value <= 50:
        return '良好'
    elif aqi_value <= 100:
        return '普通'
    elif aqi_value <= 150:
        return '對敏感族群不健康'
    elif aqi_value <= 200:
        return '對所有族群不健康'
    elif aqi_value <= 300:
        return '非常不健康'
    else:
        return '危害'

def create_aqi_map(df, output_path):
    """
    使用 Folium 建立 AQI 監測站地圖
    
    Parameters:
        df (pd.DataFrame): AQI 資料
        output_path (str): 輸出檔案路徑
    """
    # 以台灣中心點為地圖中心
    taiwan_center = [23.5, 121.0]
    
    # 建立地圖
    m = folium.Map(
        location=taiwan_center,
        zoom_start=7,
        tiles='OpenStreetMap'
    )
    
    # 加入每個監測站的標記
    for idx, row in df.iterrows():
        lat = row.get('latitude')
        lon = row.get('longitude')
        site_name = row.get('sitename', '未知站點')
        county = row.get('county', '')
        aqi = row.get('aqi', 'N/A')
        pollutant = row.get('pollutant', 'N/A')
        status = row.get('status', '')
        publish_time = row.get('publishtime', '')
        
        # 建立彈出視窗內容
        popup_html = f"""
        <div style="font-family: Arial, sans-serif; width: 250px;">
            <h4 style="margin-bottom: 10px; color: #2c3e50;">{site_name}</h4>
            <table style="width: 100%; font-size: 12px;">
                <tr><td><b>縣市：</b></td><td>{county}</td></tr>
                <tr><td><b>AQI：</b></td><td style="color: {get_aqi_color(aqi)}; font-weight: bold;">{aqi}</td></tr>
                <tr><td><b>狀態：</b></td><td>{get_aqi_status(aqi)}</td></tr>
                <tr><td><b>主要污染物：</b></td><td>{pollutant}</td></tr>
                <tr><td><b>狀態：</b></td><td>{status}</td></tr>
                <tr><td><b>發布時間：</b></td><td>{publish_time}</td></tr>
            </table>
        </div>
        """
        
        # 加入標記
        folium.CircleMarker(
            location=[lat, lon],
            radius=8,
            popup=folium.Popup(popup_html, max_width=300),
            tooltip=f"{site_name} (AQI: {aqi})",
            color=get_aqi_color(aqi),
            fill=True,
            fillColor=get_aqi_color(aqi),
            fillOpacity=0.7,
            weight=2
        ).add_to(m)
    
    # 加入圖例
    legend_html = '''
    <div style="position: fixed; 
                bottom: 50px; right: 50px; width: 200px; height: 220px; 
                background-color: white; border:2px solid grey; z-index:9999; 
                font-size:14px; padding: 10px">
        <p style="margin: 0; font-weight: bold;">AQI 空氣品質指標</p>
        <p style="margin: 5px 0;"><i class="fa fa-circle" style="color:green"></i> 0-50: 良好</p>
        <p style="margin: 5px 0;"><i class="fa fa-circle" style="color:lightgreen"></i> 51-100: 普通</p>
        <p style="margin: 5px 0;"><i class="fa fa-circle" style="color:orange"></i> 101-150: 對敏感族群不健康</p>
        <p style="margin: 5px 0;"><i class="fa fa-circle" style="color:red"></i> 151-200: 對所有族群不健康</p>
        <p style="margin: 5px 0;"><i class="fa fa-circle" style="color:purple"></i> 201-300: 非常不健康</p>
        <p style="margin: 5px 0;"><i class="fa fa-circle" style="color:darkred"></i> 300+: 危害</p>
    </div>
    '''
    m.get_root().html.add_child(folium.Element(legend_html))
    
    # 儲存地圖
    m.save(output_path)
    print(f"✓ 地圖已儲存至: {output_path}")

def save_data(df, output_dir):
    """
    儲存原始資料為 CSV 和 JSON 格式
    
    Parameters:
        df (pd.DataFrame): AQI 資料
        output_dir (Path): 輸出目錄
    """
    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    
    # 儲存 CSV
    csv_path = output_dir / f'aqi_data_{timestamp}.csv'
    df.to_csv(csv_path, index=False, encoding='utf-8-sig')
    print(f"✓ CSV 資料已儲存至: {csv_path}")
    
    # 儲存 JSON
    json_path = output_dir / f'aqi_data_{timestamp}.json'
    df.to_json(json_path, orient='records', force_ascii=False, indent=2)
    print(f"✓ JSON 資料已儲存至: {json_path}")
    
    return csv_path, json_path

def main():
    """主程式"""
    print("=" * 60)
    print("AQI 監測站資料擷取與視覺化")
    print("=" * 60)
    print()
    
    # 設定輸出目錄
    project_root = Path(__file__).parent.parent
    output_dir = project_root / 'outputs'
    output_dir.mkdir(exist_ok=True)
    
    # 1. 獲取 AQI 資料
    raw_data = fetch_aqi_data()
    
    # 2. 處理資料
    df = process_aqi_data(raw_data)
    
    if df.empty:
        print("❌ 沒有可用的資料")
        sys.exit(1)
    
    # 3. 顯示統計資訊
    print("資料統計：")
    print(f"  監測站數量: {len(df)}")
    print(f"  縣市數量: {df['county'].nunique() if 'county' in df.columns else 'N/A'}")
    if 'aqi' in df.columns:
        print(f"  平均 AQI: {df['aqi'].mean():.2f}")
        print(f"  最高 AQI: {df['aqi'].max():.0f}")
        print(f"  最低 AQI: {df['aqi'].min():.0f}")
    print()
    
    # 4. 儲存資料
    csv_path, json_path = save_data(df, output_dir)
    
    # 5. 建立地圖
    timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
    map_path = output_dir / f'aqi_map_{timestamp}.html'
    create_aqi_map(df, str(map_path))
    
    print()
    print("=" * 60)
    print("✓ 所有作業完成！")
    print(f"請開啟 {map_path} 查看互動式地圖")
    print("=" * 60)

if __name__ == "__main__":
    main()
